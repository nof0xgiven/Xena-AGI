{
  "name": "xena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests trigger.config.ts vitest.config.ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose -f docker-compose.local.yml up -d",
    "db:down": "docker compose -f docker-compose.local.yml down",
    "db:logs": "docker compose -f docker-compose.local.yml logs -f",
    "trigger:dev": "mkdir -p .trigger && NODE_OPTIONS=--localstorage-file=.trigger/localstorage.json pnpm dlx trigger.dev@latest dev --env-file .env"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@trigger.dev/sdk": "^4.4.2",
    "dotenv": "^17.3.1",
    "postgres": "^3.4.8",
    "zod": "^4.0.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@trigger.dev/build": "^4.4.2",
    "@types/node": "^25.3.5",
    "eslint": "^9.37.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
